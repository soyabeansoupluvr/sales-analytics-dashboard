# --- Streamlit ---------------------------------------------------------------
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# --- Storage (M7 Protected Store) --------------------------------------------
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
SQLITE_URL=sqlite:///data/processed/dashboard.db

# --- Security & Ethics (M6 + M8) ---------------------------------------------
# HMAC key used to pseudonymize CustomerID at ingestion. Rotate quarterly.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
PSEUDONYM_KEY=change-me-generate-32-bytes-hex

# Minimum cohort size before segments are shown to non-admin users.
SMALL_GROUP_SUPPRESSION_THRESHOLD=5

# Session throttle (requests per minute per authenticated user).
RATE_LIMIT_RPM=120

# --- Logging (M14) -----------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_DIR=logs
