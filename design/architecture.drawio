        <mxCell id="M9" value="&lt;font style=&quot;font-size: 16px;&quot;&gt;M9 · Ingestion&lt;br&gt;&lt;/font&gt;In: CSV / XLSX upload&lt;br&gt;Out: normalized frame, quality report&lt;br&gt;Rejects executable content" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6E522B;strokeColor=#6E522B;fontColor=#FFFFFF;fontSize=11;fontStyle=1;align=left;spacingLeft=8;" parent="1" vertex="1">
