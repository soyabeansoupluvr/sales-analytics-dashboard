        <mxCell id="M6" value="&lt;font style=&quot;font-size: 16px;&quot;&gt;M6 · Pseudonymization&lt;/font&gt;&lt;br&gt;In: raw CustomerID&lt;br&gt;Out: keyed pseudonym&lt;br&gt;Method: HMAC-SHA256 vault; GDPR minimization" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1B474D;strokeColor=#1B474D;fontColor=#FFFFFF;fontSize=11;fontStyle=1;align=left;spacingLeft=8;" parent="1" vertex="1">
          <mxGeometry x="241" y="575" width="360" height="90" as="geometry" />
        </mxCell>
        <mxCell id="M7" value="&lt;font style=&quot;font-size: 16px;&quot;&gt;M7 · Protected Store&lt;/font&gt;&lt;br&gt;In: cleaned frame&lt;br&gt;Out: parquet + SQLite&lt;br&gt;Encryption at rest, role-scoped views" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1B474D;strokeColor=#1B474D;fontColor=#FFFFFF;fontSize=11;fontStyle=1;align=left;spacingLeft=8;" parent="1" vertex="1">
